local player = game.Players.LocalPlayer
local RunService = game:GetService("RunService")

-- Character handler
local character, humanoid, root

local function loadCharacter(char)
    character = char
    humanoid = char:WaitForChild("Humanoid")
    root = char:WaitForChild("HumanoidRootPart")
end

loadCharacter(player.Character or player.CharacterAdded:Wait())
player.CharacterAdded:Connect(loadCharacter)

-- Variables
local noclipEnabled = false
local antiEnabled = false
local noclipConnection, antiConnection

-- ======================
-- FUNCTIONS
-- ======================

local function toggleNoclip()
    noclipEnabled = not noclipEnabled

    if noclipEnabled then
        noclipConnection = RunService.Stepped:Connect(function()
            if character then
                for _, v in ipairs(character:GetDescendants()) do
                    if v:IsA("BasePart") then
                        v.CanCollide = false
                    end
                end
            end
        end)
    else
        if noclipConnection then
            noclipConnection:Disconnect()
            noclipConnection = nil
        end
    end
end

local function toggleAnti()
    antiEnabled = not antiEnabled

    if antiEnabled then
        antiConnection = RunService.Heartbeat:Connect(function()
            if humanoid and root then
                humanoid.MaxHealth = math.huge
                humanoid.Health = math.huge

                root.AssemblyLinearVelocity =
                    Vector3.new(0, root.AssemblyLinearVelocity.Y, 0)
            end
        end)
    else
        if antiConnection then
            antiConnection:Disconnect()
            antiConnection = nil
        end

        if humanoid then
            humanoid.MaxHealth = 100
            humanoid.Health = 100
        end
    end
end

local function setSpeed(val)
    if humanoid then
        humanoid.WalkSpeed = val
    end
end

local function tpBase()
    if root then
        root.CFrame = CFrame.new(150, 50, -200) -- ubah sesuai map
    end
end

