local StarFishingTab = Window:Tab({
    Title = "Star Fishing",
    Icon = "star",
    IconColor = Color3.fromRGB(0,50,150),
    IconShape = "Square",
    IconThemed = true,
    Border = true
})

-- ======================
-- HEADER
-- ======================

StarFishingTab:Paragraph({
    Title = "Star Fishing Auto",
    Desc = "Auto Fish Instant Reel & Confirm"
})

StarFishingTab:Divider()

-- ======================
-- MAIN SECTION
-- ======================

local Main = StarFishingTab:Section({
    Title = "Auto Fishing",
    Icon = "star",
    Opened = true
})

local AutoFish = false
local AutoSell = false
local SelectedGalaxy = "Self"

-- ======================
-- GALAXY SELECTOR
-- ======================

Main:Dropdown({
    Title = "Best Galaxy Farm",
    Values = {"Self","Milky Way","Andromeda","Sombrero","Whirlpool"},
    Default = "Self",
    Callback = function(Value)

        SelectedGalaxy = Value

        WindUI:Notify({
            Title = "Galaxy Selected",
            Content = Value,
            Duration = 3
        })

    end
})

-- ======================
-- AUTO FISH
-- ======================

Main:Toggle({
    Title = "Auto Fish (Instant Reel)",
    Default = false,
    Callback = function(Value)

        AutoFish = Value

        WindUI:Notify({
            Title = "Star Fishing",
            Content = Value and "Auto Fish Enabled" or "Auto Fish Disabled",
            Duration = 3
        })

        if Value then

            local Players = game:GetService("Players")
            local ReplicatedStorage = game:GetService("ReplicatedStorage")
            local Client = Players.LocalPlayer

            local function GetRoot(Character)
                return Character and Character:FindFirstChild("HumanoidRootPart")
            end

            local function GetHumanoid(Character)
                return Character and Character:FindFirstChild("Humanoid")
            end

            local function Cast()

                local Character = Client.Character
                local Humanoid = GetHumanoid(Character)
                local Root = GetRoot(Character)

                if not Root then return end

                local Rod = Character:FindFirstChild("Rod")
                if not Rod then return end

                local Farming = SelectedGalaxy == "Self"
                    and Root
                    or workspace.Galaxies:FindFirstChild(SelectedGalaxy)
                    or Root

                local FarmType = {
                    Farming:GetPivot().Position + Vector3.new(0,5,0),
                    Farming:GetPivot().LookVector
                }

                local CastArguments = {
                    Humanoid,
                    FarmType[1],
                    FarmType[2],
                    Rod.Model.Nodes.RodTip.Attachment
                }

                ReplicatedStorage.Events.Global.Cast:FireServer(unpack(CastArguments))
                ReplicatedStorage.Events.Global.WithdrawBobber:FireServer(Client.Character.Humanoid)

            end

            spawn(function()

                while AutoFish and task.wait() do

                    local Character = Client.Character
                    local Root = GetRoot(Character)

                    if Root then
                        Cast()
                    end

                end

            end)

            -- Auto Confirm Catch

            ReplicatedStorage.Events.Global.ClientRecieveItems.OnClientEvent:Connect(function(...)

                local Data = {...}
                local Info = Data[4] or {}
                local TimingTbl = Data[6] or {}

                for Index, StarData in Info do

                    local Id = StarData["id"]

                    if Id then
                        task.wait(TimingTbl[Index] or 3)
                        ReplicatedStorage.Events.Global.ClientItemConfirm:FireServer(Id)
                    end

                end

            end)

        end

    end
})

-- ======================
-- AUTO SELL
-- ======================

Main:Toggle({
    Title = "Auto Sell Stars",
    Default = false,
    Callback = function(Value)

        AutoSell = Value

        WindUI:Notify({
            Title = "Star Fishing",
            Content = Value and "Auto Sell Enabled" or "Auto Sell Disabled",
            Duration = 3
        })

        spawn(function()

            while AutoSell do

                local args = {
                    [1] = {
                        ["id"] = "sell-all",
                        ["text"] = "Sell all my stars",
                        ["npc"] = "Star Merchant"
                    }
                }

                game:GetService("ReplicatedStorage")
                .Dialogue
                .Events
                .Global
                .ClientChoosesDialogueOption
                :FireServer(unpack(args))

                task.wait(10)

            end

        end)

    end
})

