InstantTab:Paragraph({
    Title = "Instant Interact Information",
    Desc = [[
━━━━━━━━━━━━━━━━━━━━━━━━

⚡ This feature automatically triggers
all ProximityPrompt interactions instantly.

✔ Works in most games using ProximityPrompt
❌ May not work in games with custom systems
❌ May not work if the developer patched it

Tip:
If the feature does not work,
the game may have anti-cheat protection.

Use responsibly 

━━━━━━━━━━━━━━━━━━━━━━━━
]]
})

-- ======================
-- SERVICES
-- ======================
local ProximityPromptService = game:GetService("ProximityPromptService")

-- ======================
-- VARIABLES
-- ======================
local InstantEnabled = false
local PromptConnection = nil

-- ======================
-- TOGGLE SYSTEM
-- ======================
InstantTab:Toggle({
    Title = "Instant Interact",
    Description = "Automatically activate ProximityPrompts",
    Default = false,
    Callback = function(State)

        InstantEnabled = State

        if State then

            PromptConnection = ProximityPromptService.PromptButtonHoldBegan:Connect(function(Prompt)
                if InstantEnabled then
                    fireproximityprompt(Prompt)
                end
            end)

            WindUI:Notify({
                Title = "Instant Interact",
                Content = "Feature Enabled",
                Duration = 3
            })

        else

            if PromptConnection then
                PromptConnection:Disconnect()
                PromptConnection = nil
            end

            WindUI:Notify({
                Title = "Instant Interact",
                Content = "Feature Disabled",
                Duration = 3
            })

        end
    end
})
