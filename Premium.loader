    Title = "Fisch Script Hub",
    Desc = [[
Status : Ready
Scripts : 4 Available

Features
• Fast Execute
• Safe Loader
• Easy Access
]]
})

FischTab:Divider()

-- ======================
-- SYSTEM
-- ======================
local executed = {}

local function notify(text)
    WindUI:Notify({
        Title = "Fisch Hub",
        Content = text,
        Duration = 3
    })
end

local function runScript(name,url)

    if executed[name] then
        notify(name.." already executed")
        return
    end

    local success,err = pcall(function()
        loadstring(game:HttpGet(url,true))()
    end)

    if success then
        executed[name] = true
        notify(name.." loaded successfully")
    else
        notify(name.." failed to load")
        warn(err)
    end

end

