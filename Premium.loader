-- ======================
-- SYSTEM
-- ======================
local function runScript(url,name)

    local success,err = pcall(function()
        loadstring(game:HttpGet(url,true))()
    end)

    WindUI:Notify({
        Title = "Avatar System",
        Content = success and (name.." loaded") or (name.." failed"),
        Duration = 3,
        Icon = success and "check" or "x"
    })

    if not success then
        warn(err)
    end

end

