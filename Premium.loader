-- ======================
-- ⚡ INSTANT FISHING V1
-- ======================
local AutoFishV1 = false

IkanBrainrotTab:Toggle({
    Title = "Instant Fishing V1",
    Desc = "Auto fishing normal speed",
    Icon = "fish",
    Default = false,
    Callback = function(Value)
        AutoFishV1 = Value

        if AutoFishV1 then
            task.spawn(function()
                local ReplicatedStorage = game:GetService("ReplicatedStorage")
                local Remotes = ReplicatedStorage:FindFirstChild("Remotes")
                local FishRequest = Remotes:FindFirstChild("FishRequest")
                local FishingCompleted = Remotes:FindFirstChild("FishingCompleted")

                while AutoFishV1 do
                    FishRequest:InvokeServer(0.89123910665512)
                    FishingCompleted:FireServer(0.89123910665512)
                    task.wait(0)
                end
            end)
        end
    end
})

-- ======================
-- ⚡ INSTANT FISHING V2
-- ======================
local AutoFishV2 = false

IkanBrainrotTab:Toggle({
    Title = "Instant Fishing V2",
    Desc = "Ultra fast fishing (Heartbeat)",
    Icon = "zap",
    Default = false,
    Callback = function(Value)
        AutoFishV2 = Value

        if AutoFishV2 then
            task.spawn(function()
                local ReplicatedStorage = game:GetService("ReplicatedStorage")
                local Remotes = ReplicatedStorage:FindFirstChild("Remotes")
                local FishRequest = Remotes:FindFirstChild("FishRequest")
                local FishingCompleted = Remotes:FindFirstChild("FishingCompleted")

                local RunService = game:GetService("RunService")

                while AutoFishV2 do
                    FishRequest:InvokeServer(0.89123910665512)
                    FishingCompleted:FireServer(0.89123910665512)
                    RunService.Heartbeat:Wait()
                end
            end)
        end
    end
})
