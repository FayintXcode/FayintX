local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- // 1. UNIVERSAL EXECUTOR DETECTOR
local function GetExecutor()
    local name = "Unknown"
    local success, result = pcall(function()
        return (identifyexecutor or getexecutorname)()
    end)
    
    if success and result then 
        name = result 
    else
        if delta then name = "Delta"
        elseif fluxus then name = "Fluxus"
        elseif codex then name = "Codex"
        elseif arceus then name = "Arceus X"
        elseif KRNL_LOADED then name = "KRNL"
        end
    end
    return name
end

-- // 2. DYNAMIC RANK SYSTEM
local function GetRank()
    local name = LocalPlayer.Name
    
    if name == "Nama Lu" then 
        return "Developer" 
    elseif name == "pandu239" or name == "fansbangguga" then 
        return "Admin"
    else 
        return "Member" 
    end
end

-- // 3. GET USER HEADSHOT (Buat bagian Image)
local function GetUserHeadshot()
    local content = "rbxassetid://120300880947393"
    pcall(function()
        content = Players:GetUserThumbnailAsync(
            LocalPlayer.UserId,
            Enum.ThumbnailType.HeadShot,
            Enum.ThumbnailSize.Size100x100
        )
    end)
    return content
end

-- // 4. DESCRIPTION BUILDER
local function BuildDesc()
    return string.format(
        "Username: %s\nAccount Age: %d Days\nExecutor: %s\nRank: %s",
        LocalPlayer.Name,
        LocalPlayer.AccountAge,
        GetExecutor(),
        GetRank()
    )
end

