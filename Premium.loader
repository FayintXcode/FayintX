-- ======================
-- ⚙️ EXECUTE FUNCTION
-- ======================
local function runScript(name,url)

    local success,err = pcall(function()
        loadstring(game:HttpGet(url,true))()
    end)

    if success then
        WindUI:Notify({
            Title = "Tsunami Hub",
            Content = name.." loaded successfully",
            Duration = 3,
            Icon = "check"
        })
    else
        WindUI:Notify({
            Title = "Tsunami Hub",
            Content = name.." failed to load",
            Duration = 3,
            Icon = "x"
        })
    end

end

