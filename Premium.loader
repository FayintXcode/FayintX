    Icon = "fish",
    IconColor = Color3.fromRGB(0, 50, 150),
    IconShape = "Square",
    IconThemed = true,
    Border = true
})

-- ================================
-- HEADER
-- ================================

RYUTab:Paragraph({
    Title = "RYU Fishing System",
    Desc = [[
Auto Fishing Super Fast
Auto Sell System
Adjustable Loop Delay
]]
})

RYUTab:Divider()

-- ================================
-- LOGIC
-- ================================

local RYU = {
    Enabled = false,
    SellAll = false,
    Delay = 0.15,
    Thread = nil,
    SellDebounce = 0
}

local RYU_Charge
local RYU_Minigame
local RYU_Complete
local RYU_Sell

task.spawn(function()

    local ReplicatedStorage = game:GetService("ReplicatedStorage")

    local ok, net = pcall(function()
        return ReplicatedStorage:FindFirstChild("Packages")
        and ReplicatedStorage.Packages:FindFirstChild("_Index")
        and ReplicatedStorage.Packages._Index:FindFirstChild("sleitnick_net@0.2.0")
        and ReplicatedStorage.Packages._Index["sleitnick_net@0.2.0"]:FindFirstChild("net")
    end)

    if not ok or not net then return end

    RYU_Charge   = net:FindFirstChild("RF/ChargeFishingRod")
    RYU_Minigame = net:FindFirstChild("RF/RequestFishingMinigameStarted")
    RYU_Complete = net:FindFirstChild("RE/FishingCompleted")
    RYU_Sell     = net:FindFirstChild("RF/SellAllItems")

end)

local function DoRYUFish()
    pcall(function()
        RYU_Charge:InvokeServer()
        RYU_Minigame:InvokeServer(-1.233184814453125,0.9909137366173792,os.clock())
        RYU_Complete:FireServer()
    end)
end

local function DoRYUSell()
    pcall(function()
        RYU_Sell:InvokeServer()
    end)
end

local function ryuStartLoop()

    if RYU.Thread then
        task.cancel(RYU.Thread)
        RYU.Thread = nil
    end

    RYU.Thread = task.spawn(function()

        while RYU.Enabled do

            DoRYUFish()

            if RYU.SellAll and (tick() - RYU.SellDebounce) > 10 then
                DoRYUSell()
                RYU.SellDebounce = tick()
            end

            task.wait(RYU.Delay)

        end

    end)

end

local function ryuStopLoop()

    RYU.Enabled = false

    if RYU.Thread then
        task.cancel(RYU.Thread)
        RYU.Thread = nil
    end

end

-- ================================
-- TOGGLES
-- ================================

RYUTab:Toggle({
    Title = "Auto Fishing Super Fast",
    Default = false,
    Callback = function(state)

        RYU.Enabled = state

        if state then

            ryuStartLoop()

            WindUI:Notify({
                Title = "RYU Fishing",
                Content = "Auto Fishing Enabled",
                Duration = 3
            })

        else

            ryuStopLoop()

            WindUI:Notify({
                Title = "RYU Fishing",
                Content = "Auto Fishing Disabled",
                Duration = 3
            })

        end
    end
})

RYUTab:Toggle({
    Title = "Auto Sell All",
    Default = false,
    Callback = function(state)
        RYU.SellAll = state
    end
})

-- ================================
-- DELAY INPUT
-- ================================

RYUTab:Input({
    Title = "Loop Delay (Seconds)",
    Desc = "Range 0.1 - 2 | Default: 0.15",
    Placeholder = "0.1 - 2",
    Callback = function(val)

        local num = tonumber(val)

        if not num then

            WindUI:Notify({
                Title = "Invalid Input",
                Content = "Enter a valid number",
                Duration = 3
            })

            return
        end

        num = math.clamp(num,0.1,2)

        RYU.Delay = num

        WindUI:Notify({
            Title = "Delay Updated",
            Content = "Loop Delay: "..num.."s",
            Duration = 2
        })

        if RYU.Enabled then
            ryuStopLoop()
            RYU.Enabled = true
            ryuStartLoop()
        end

    end
})
