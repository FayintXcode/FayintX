local function runDDS()

    local success,err = pcall(function()
        loadstring(game:HttpGet(
        "https://raw.githubusercontent.com/societyqz/lithhub/refs/heads/main/autofarmv1",true))()
    end)

    WindUI:Notify({
        Title = "DDS System",
        Content = success and "Script loaded" or "Failed to load",
        Duration = 3,
        Icon = success and "check" or "x"
