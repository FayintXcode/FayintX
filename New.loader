local BugSettings = {
    WebhookURL = "https://discord.com/api/webhooks/1476252269312868503/6Trh3ihDqWNC2deLhgnNLWb_ZANMWlUYC0DM_NRHTHc4hf7boAWRrQh_DM539FUKUREE",
    Title = "",
    Desc = ""
}

-- Input bug title
BugTab:Input({
    Title = "Bug Title",
    Placeholder = "Enter bug title...",
    Callback = function(v)
        BugSettings.Title = v
    end
})

-- Input bug description
BugTab:Input({
    Title = "Bug Description",
    Placeholder = "Describe the bug...",
    Callback = function(v)
        BugSettings.Desc = v
    end
})

-- Button send bug
BugTab:Button({
    Title = "Send Bug",
    Desc = "Send to Discord webhook",
    Icon = "send",
    Callback = function()
        if BugSettings.Title == "" or BugSettings.Desc == "" then
            WindUI:Notify({
                Title = "Error ❌",
                Content = "Title and Description must be filled!",
                Duration = 4,
                Icon = "x"
            })
            return
        end

        local httpRequest = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
        if not httpRequest then
            WindUI:Notify({
                Title = "Error ❌",
                Content = "Executor does not support HTTP requests",
                Duration = 4,
                Icon = "x"
            })
            return
        end

        local Players = game:GetService("Players")
        local LocalPlayer = Players.LocalPlayer
        local HttpService = game:GetService("HttpService")

        local payload = {
            ["username"] = "Bug Reporter",
            ["avatar_url"] = "https://files.catbox.moe/em40tz.jpg",
            ["embeds"] = {{
                ["title"] = BugSettings.Title,
                ["color"] = 15105570,
                ["fields"] = {
                    {["name"] = "👤 User Info", ["value"] = string.format("Display: %s\nUser: %s\nID: %s", LocalPlayer.DisplayName, LocalPlayer.Name, LocalPlayer.UserId), ["inline"] = true},
                    {["name"] = "📝 Description", ["value"] = BugSettings.Desc, ["inline"] = false},
                    {["name"] = "🎮 Game Info", ["value"] = string.format("Place ID: %s\nJob: %s", game.PlaceId, game.JobId), ["inline"] = true}
                },
                ["footer"] = {["text"]="Time: "..os.date("%c")}
            }}
        }

        local success, err = pcall(function()
            httpRequest({
                Url = BugSettings.WebhookURL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode(payload)
            })
        end)

        if success then
            WindUI:Notify({
                Title = "Success ✅",
                Content = "Bug sent successfully!",
                Duration = 4,
                Icon = "check"
            })
        else
            WindUI:Notify({
                Title = "Failed ❌",
                Content = "Error: "..tostring(err),
                Duration = 4,
                Icon = "x"
            })
        end
    end
})

