-- ⚡ REMOTE TAB (CODE UI)
-- ======================

local RemoteTab = Window:Tab({
    Title = "Remote",
    Icon = "terminal"
})

-- ======================
-- STATE
-- ======================

local remoteText = "game:GetService('ReplicatedStorage')"
local fireCount = 1
local delay = 0.1

-- ======================
-- 💻 CODE PREVIEW (REAL)
-- ======================

local CodeBox = RemoteTab:Code({
    Title = "Code Preview",
    Code = remoteText
})

RemoteTab:Divider()

-- ======================
-- INPUT REMOTE
-- ======================

RemoteTab:Input({
    Title = "Remote Code",
    Desc = "Paste remote code here",
    Placeholder = "game:GetService(...)",
    Callback = function(text)
        remoteText = text
        
        -- update code preview (INI YANG PENTING 🔥)
        CodeBox:SetCode(text)
    end
})

-- ======================
-- FIRE COUNT
-- ======================

RemoteTab:Input({
    Title = "Fire Count",
    Desc = "How many times to execute",
    Placeholder = "1",
    Callback = function(v)
        fireCount = tonumber(v) or 1
    end
})

-- ======================
-- DELAY
-- ======================

RemoteTab:Input({
    Title = "Fire Delay",
    Desc = "Delay between executions (seconds)",
    Placeholder = "0.1",
    Callback = function(v)
        delay = tonumber(v) or 0.1
    end
})

RemoteTab:Divider()

-- ======================
-- BUTTONS
-- ======================

-- EXECUTE
RemoteTab:Button({
    Title = "🚀 Execute Remote",
    Icon = "play",
    Callback = function()
        for i = 1, fireCount do
            pcall(function()
                loadstring(remoteText)()
            end)
            task.wait(delay)
        end

        WindUI:Notify({
            Title = "Remote",
            Content = "Executed 🔥",
            Duration = 3
        })
    end
})

-- COPY
RemoteTab:Button({
    Title = "📋 Copy Code",
    Icon = "copy",
    Callback = function()
        if setclipboard then
            setclipboard(remoteText)
        end

        WindUI:Notify({
            Title = "Clipboard",
            Content = "Copied 📋",
            Duration = 3
        })
    end
})

-- CLEAR
RemoteTab:Button({
    Title = "🧹 Clear",
    Icon = "trash",
    Callback = function()
        remoteText = ""
        CodeBox:SetCode("-- empty")

        WindUI:Notify({
            Title = "Remote",
            Content = "Cleared 🧹",
            Duration = 3
        })
    end
})
