    end
})

-- Choose rating
for i = 1,5 do
    RatingTab:Button({
        Title = "Select " .. i .. " ⭐",
        Icon = "star",
        Callback = function()
            RatingSettings.Stars = i
            WindUI:Notify({
                Title = "Rating",
