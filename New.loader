-- 👻 KORBLOX HEADLESS TAB (FIX)
-- ======================
local KorbloxTab = Window:Tab({
    Title = "Korblox Headless",
    Icon = "skull"
})

-- Variables
local korbloxEnabled = false
local charConnection -- simpan koneksi karakter

-- Function untuk apply Korblox headless
local function applyKorblox(character)
    if not character then return end
    
    local head = character:FindFirstChild("Head")
    if head then
        head.MeshId = "http://www.roblox.com/asset/?id=6686307858"
        head.TextureID = "http://www.roblox.com/asset/?id=6686307858"
        head.Transparency = 1
    end

    local rightLowerLeg = character:FindFirstChild("RightLowerLeg")
    if rightLowerLeg then
        rightLowerLeg.MeshId = "http://www.roblox.com/asset/?id=902942093"
        rightLowerLeg.Transparency = 1
    end

    local rightUpperLeg = character:FindFirstChild("RightUpperLeg")
    if rightUpperLeg then
        rightUpperLeg.MeshId = "http://www.roblox.com/asset/?id=902942096"
        rightUpperLeg.TextureID = "http://www.roblox.com/asset/?id=902843398"
    end

    local rightFoot = character:FindFirstChild("RightFoot")
    if rightFoot then
        rightFoot.MeshId = "http://www.roblox.com/asset/?id=902942089"
        rightFoot.Transparency = 1
    end
end

-- Toggle Korblox Headless
KorbloxTab:Toggle({
    Title = "👻 Enable Korblox Headless",
    Desc = "Ubah karakter menjadi Korblox Headless + Visual",
    Default = false,
    Callback = function(state)
        korbloxEnabled = state
        local player = game.Players.LocalPlayer

        -- Hapus koneksi lama dulu biar nggak numpuk
        if charConnection then
            charConnection:Disconnect()
            charConnection = nil
        end

        if korbloxEnabled then
            -- Apply sekarang jika character sudah ada
            if player.Character then
                applyKorblox(player.Character)
            end

            -- Apply setiap spawn baru tapi hanya 1 koneksi
            charConnection = player.CharacterAdded:Connect(function(char)
                task.delay(1, function()
                    if korbloxEnabled then
                        applyKorblox(char)
                    end
                end)
            end)

            WindUI:Notify({
                Title = "Korblox Headless",
                Content = "✅ Enabled",
                Duration = 2,
                Icon = "skull"
            })
        else
            WindUI:Notify({
                Title = "Korblox Headless",
                Content = "❌ Disabled (restart needed to reset parts)",
                Duration = 2,
                Icon = "skull"
            })
        end
    end
})
