-- ======================
local executed = {}

local function notify(title,text)
    WindUI:Notify({
        Title = title,
        Content = text,
        Duration = 3
    })
end

local function runScript(name,url)

    if executed[name] then
        notify(name,"Script already executed")
        return
    end

    local success,err = pcall(function()
        loadstring(game:HttpGet(url,true))()
    end)

    if success then
        executed[name] = true
        notify(name,"Script loaded")
    else
        notify(name,"Failed to load")
        warn(err)
    end

end

