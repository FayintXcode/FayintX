-- ======================
-- 👻 INVISIBLE TAB
-- ======================

local InvisibleTab = Window:Tab({
    Title = "Invisible",
    Icon = "eye-off"
})

local invisibleEnabled = false
local running = false

InvisibleTab:Toggle({
    Title = "👻 Enable FE Invisible",
    Desc = "Clone method (hard to detect by other players)",
    Default = false,
    Callback = function(state)
        invisibleEnabled = state

        if invisibleEnabled and not running then
            running = true

            task.spawn(function()
                local lplr = game.Players.LocalPlayer
                local char = lplr.Character or lplr.CharacterAdded:Wait()
                char.Archivable = true

                local oldChar = char
                local oldCFrame = char:GetPivot()

                oldChar:FindFirstChild("HumanoidRootPart").CFrame = CFrame.new(1e5,1e6,1e5)
                task.wait(0.1)
                oldChar:FindFirstChild("HumanoidRootPart").Anchored = true

                local clone = char:Clone()
                clone.Parent = workspace
                lplr.Character = clone

                workspace.CurrentCamera.CameraSubject = clone:FindFirstChildOfClass("Humanoid")
                clone:FindFirstChild("HumanoidRootPart").CFrame = oldCFrame
                clone:FindFirstChild("HumanoidRootPart").Anchored = false

                for _,v in pairs(clone:GetDescendants()) do
                    if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
                        v.Transparency = 0.5
                    end
                end

                WindUI:Notify({
                    Title = "Invisible",
                    Content = "Enabled 👻",
                    Duration = 3
                })

                local function revert()
                    if clone and clone.Parent then
                        local pos = clone:GetPivot()
                        clone:Destroy()

                        workspace.CurrentCamera.CameraSubject = oldChar:FindFirstChildOfClass("Humanoid")
                        oldChar:FindFirstChild("HumanoidRootPart").Anchored = false

                        lplr.Character = oldChar
                        lplr.Character:PivotTo(pos)

                        WindUI:Notify({
                            Title = "Invisible",
                            Content = "Disabled ❌",
                            Duration = 3
                        })
                    end
                end

                clone:FindFirstChildOfClass("Humanoid").Died:Connect(revert)

                while invisibleEnabled do
                    task.wait(0.5)
                end

                revert()
                running = false
            end)

        elseif not invisibleEnabled then
            WindUI:Notify({
                Title = "Invisible",
                Content = "Turning Off...",
                Duration = 2
            })
        end
    end
})

