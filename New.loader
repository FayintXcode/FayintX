local StatsService = game:GetService("Stats")
local RunService = game:GetService("RunService")


local MyTag = Window:Tag({
    Title = "Fps: Calculating... | Ping: Calculating...",
    icon = "activity",
    Color = WindUI:Gradient({
        [0]   = { Color = Color3.fromHex("#1f1f1f"), Transparency = 0 }, 
        [50]  = { Color = Color3.fromHex("#0089EB"), Transparency = 0 }, 
        [100] = { Color = Color3.fromHex("#00EBFF"), Transparency = 0 },
    }, {
        Rotation = 45,
    }),
})


task.spawn(function()
    while task.wait(0.5) do
        pcall(function()
            
            local fps = math.floor(1 / RunService.RenderStepped:Wait())
            
            
            local ping = 0
            local success, err = pcall(function()
                ping = math.floor(StatsService.Network.ServerStatsItem["Data Ping"]:GetValue())
            end)
            
            
            if MyTag and MyTag.SetTitle then
                MyTag:SetTitle(string.format("Fps:%d | Ping:%d", fps, ping))
            end
        end)
    end
end)
