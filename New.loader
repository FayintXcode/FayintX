local remoteText = "game:GetService('ReplicatedStorage')"
local fireCount = 1
local delay = 0.1

-- ======================
-- CODE PREVIEW
-- ======================

local CodeBox = RemoteTab:Code({
    Title = "Code Preview",
    Code = remoteText
})

RemoteTab:Divider()

-- ======================
-- INPUT SECTION
-- ======================

local InputSection = RemoteTab:Section({
    Title = "Remote Settings",
    Icon = "settings",
    Opened = true
})

InputSection:Input({
    Title = "Remote Code",
    Desc = "Paste remote code here",
    Placeholder = "game:GetService(...)",
    Callback = function(text)

        remoteText = text
        CodeBox:SetCode(text)

    end
})

InputSection:Input({
    Title = "Fire Count",
    Desc = "Number of executions",
    Placeholder = "1",
    Callback = function(v)

        fireCount = tonumber(v) or 1

    end
})

InputSection:Input({
    Title = "Delay",
    Desc = "Delay between executions",
    Placeholder = "0.1",
    Callback = function(v)

        delay = tonumber(v) or 0.1

    end
})

RemoteTab:Divider()

-- ======================
-- ACTION SECTION
-- ======================

local ActionSection = RemoteTab:Section({
    Title = "Actions",
    Icon = "play-circle",
    Opened = true
})

ActionSection:Button({
    Title = "Execute Remote",
    Icon = "play",
    Callback = function()

        for i = 1, fireCount do

            pcall(function()
                loadstring(remoteText)()
            end)

            task.wait(delay)

        end

        WindUI:Notify({
            Title = "Remote",
            Content = "Execution finished",
            Duration = 3
        })

    end
})

ActionSection:Button({
    Title = "Copy Code",
    Icon = "copy",
    Callback = function()

        if setclipboard then
            setclipboard(remoteText)
        end

        WindUI:Notify({
            Title = "Clipboard",
            Content = "Code copied",
            Duration = 3
        })

    end
})

ActionSection:Button({
    Title = "Clear Code",
    Icon = "trash",
    Callback = function()

        remoteText = ""
        CodeBox:SetCode("-- empty")

        WindUI:Notify({
            Title = "Remote",
            Content = "Code cleared",
            Duration = 3
        })

    end
})
