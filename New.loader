local KorbloxTab = Window:Tab({
    Title = "Korblox Headless",
    Icon = "skull"
})

local player = game.Players.LocalPlayer
local korbloxEnabled = false
local charConnection

-- ======================
-- APPLY FUNCTION
-- ======================
local function applyKorblox(char)

    local parts = {
        Head = {
            MeshId = "http://www.roblox.com/asset/?id=6686307858",
            TextureID = "http://www.roblox.com/asset/?id=6686307858",
            Transparency = 1
        },

        RightLowerLeg = {
            MeshId = "http://www.roblox.com/asset/?id=902942093",
            Transparency = 1
        },

        RightUpperLeg = {
            MeshId = "http://www.roblox.com/asset/?id=902942096",
            TextureID = "http://www.roblox.com/asset/?id=902843398"
        },

        RightFoot = {
            MeshId = "http://www.roblox.com/asset/?id=902942089",
            Transparency = 1
        }
    }

    for partName, data in pairs(parts) do
        local part = char:FindFirstChild(partName)
        if part then
            for property,value in pairs(data) do
                pcall(function()
                    part[property] = value
                end)
            end
        end
    end

end

-- ======================
-- TOGGLE
-- ======================
KorbloxTab:Toggle({
    Title = "Enable Korblox Headless",
    Desc = "Visual Korblox + Headless",
    Default = false,

    Callback = function(state)

        korbloxEnabled = state

        if charConnection then
            charConnection:Disconnect()
            charConnection = nil
        end

        if state then

            if player.Character then
                applyKorblox(player.Character)
            end

            charConnection = player.CharacterAdded:Connect(function(char)
                task.delay(1,function()
                    if korbloxEnabled then
                        applyKorblox(char)
                    end
                end)
            end)

            WindUI:Notify({
                Title = "Korblox Headless",
                Content = "Enabled",
                Duration = 2,
                Icon = "skull"
            })

        else

            WindUI:Notify({
                Title = "Korblox Headless",
                Content = "Disabled (Reset character to remove)",
                Duration = 2,
                Icon = "skull"
            })

        end
    end
})
