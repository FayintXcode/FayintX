-- ======================
local HubTab = Window:Tab({
    Title = "Blox Hub",
    Icon = "leaf"
})

local executed = {}

local function notify(text)
    WindUI:Notify({
        Title = "Blox Hub",
        Content = text,
        Duration = 3
    })
end

local function runHub(name, func)
    if executed[name] then
        notify(name .. " sudah dijalankan!")
        return
    end

    local success, err = pcall(func)

    if success then
        executed[name] = true
        notify(name .. " berhasil!")
    else
        notify("Gagal jalanin " .. name)
        warn(err)
    end
end

