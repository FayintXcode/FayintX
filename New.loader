local FischTab = Window:Tab({
    Title = "Fisch",
    Icon = "fish"
})

local executed = {}

local function notify(text)
    WindUI:Notify({
        Title = "Fisch",
        Content = text,
        Duration = 3,
    })
end

local function runScript(name, url)
    if executed[name] then
        notify(name .. " sudah dijalankan!")
        return
    end

    local success, err = pcall(function()
        loadstring(game:HttpGet(url))()
    end)

    if success then
        executed[name] = true
        notify(name .. " berhasil!")
    else
        notify("Gagal jalanin " .. name)
        warn(err)
    end
end

