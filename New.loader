local function runScript(name,url)

    local success,err = pcall(function()
        loadstring(game:HttpGet(url,true))()
    end)

    WindUI:Notify({
        Title = name,
        Content = success and "Script loaded" or "Failed to load",
        Duration = 3
    })

    if not success then
        warn(err)
    end

end

