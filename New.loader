    Title = "Settings",
    Icon = "settings"
})

local TeleportService = game:GetService("TeleportService")
local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer
local PlaceId = game.PlaceId

-- Rejoin
SettingsTab:Button({
    Title = "🔁 Rejoin Server",
    Desc = "Reconnect to server now",
    Callback = function()
        WindUI:Notify({
            Title = "Rejoin",
            Content = "🔁 Rejoining...",
            Duration = 2
        })
        TeleportService:Teleport(PlaceId, player)
    end
})

SettingsTab:Divider()

-- Server Hop
SettingsTab:Button({
    Title = "🌍 Server Hop",
    Desc = "Switch to random server",
    Callback = function()
        local servers = {}
        local req = game:HttpGetAsync("https://games.roblox.com/v1/games/"..PlaceId.."/servers/Public?sortOrder=Asc&limit=100")
        local data = HttpService:JSONDecode(req)

        for _,v in pairs(data.data) do
            if v.playing < v.maxPlayers then
                table.insert(servers, v.id)
            end
        end

        if #servers > 0 then
            local randomServer = servers[math.random(1,#servers)]
            WindUI:Notify({
                Title = "Server Hop",
                Content = "🌍 Switching server...",
                Duration = 2
            })
            TeleportService:TeleportToPlaceInstance(PlaceId, randomServer, player)
        else
            WindUI:Notify({
                Title = "Server Hop",
                Content = "❌ No server found",
                Duration = 3
            })
        end
    end
})

SettingsTab:Divider()

-- Low Server
SettingsTab:Button({
    Title = "🧊 Join Low Server",
    Desc = "Join the least populated server",
    Callback = function()
        local lowest = nil
        local lowestCount = math.huge
        local req = game:HttpGetAsync("https://games.roblox.com/v1/games/"..PlaceId.."/servers/Public?sortOrder=Asc&limit=100")
        local data = HttpService:JSONDecode(req)

        for _,v in pairs(data.data) do
            if v.playing < lowestCount and v.playing > 0 then
                lowestCount = v.playing
                lowest = v.id
            end
        end

        if lowest then
            WindUI:Notify({
                Title = "Low Server",
                Content = "🧊 Joining low server...",
                Duration = 2
            })
            TeleportService:TeleportToPlaceInstance(PlaceId, lowest, player)
        else
            WindUI:Notify({
                Title = "Low Server",
                Content = "❌ No server found",
                Duration = 3
            })
        end
    end
})

SettingsTab:Divider()

-- Join JobId
SettingsTab:Input({
    Title = "🆔 Join JobId",
    Desc = "Enter server JobId",
    Placeholder = "Example: 84d603f-xxxx",
    Callback = function(jobId)
        if jobId and jobId ~= "" then
            WindUI:Notify({
                Title = "Join JobId",
                Content = "🚀 Connecting...",
                Duration = 2
            })
            TeleportService:TeleportToPlaceInstance(PlaceId, jobId, player)
        end
    end
})

SettingsTab:Divider()

-- Copy JobId
SettingsTab:Button({
    Title = "📋 Copy JobId",
    Desc = "Copy current server JobId",
    Callback = function()
        setclipboard(game.JobId)
        WindUI:Notify({
            Title = "JobId",
            Content = "📋 Copied!",
            Duration = 2
        })
    end
})

SettingsTab:Divider()

-- Theme Changer
SettingsTab:Paragraph({
    Title = "🎨 Theme",
    Desc = "Change UI theme"
})

SettingsTab:Dropdown({
    Title = "🎨 Theme Changer",
    Values = {"Dark","Light","Rose","Plant","Red","Indigo","Sky","Violet","Amber","Emerald","Midnight","Crimson","Monokai Pro","Cotton Candy","Rainbow"},
    Multi = false,
    AllowNone = false,
    Default = "Violet",
    Callback = function(option)
        local selected = tostring(option)
        pcall(function() WindUI:SetTheme(selected) end)
        WindUI:Notify({
            Title = "Theme",
            Content = "Theme changed to " .. selected,
            Duration = 3
        })
    end
})
