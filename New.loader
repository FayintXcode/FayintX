local SimulatorTab = Window:Tab({
    Title = "Simulator",
    Icon = "cpu"
})

local ReplicatedStorage = game:GetService("ReplicatedStorage")

_G.AutoClickerV2Enabled = false

local NetworkModule

pcall(function()
    local modulesFolder = ReplicatedStorage:WaitForChild("Modules", 5)
    if modulesFolder then
        local network = modulesFolder:FindFirstChild("Network")
        if network then
            NetworkModule = require(network)
        end
    end
end)

local function fireClick()
    if NetworkModule and type(NetworkModule.FireServer) == "function" then
        pcall(function()
            NetworkModule:FireServer("Tap", true)
        end)
    end
end

task.spawn(function()
    while true do
        if _G.AutoClickerV2Enabled then
            fireClick()
        end
        task.wait()
    end
end)

SimulatorTab:Toggle({
    Title = "Auto Clicker V2",
    Desc = "Auto tap for simulator",
    Default = false,
    Callback = function(v)
        _G.AutoClickerV2Enabled = v
    end
})

