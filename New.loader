            WindUI:Notify({
                Title = "Error ❌",
                Content = "Please fill your message first!",
                Duration = 3
            })
            return
        end

        local httpRequest = (syn and syn.request) or (http and http.request) or http_request or request
        if not httpRequest then
            WindUI:Notify({
                Title = "Error ❌",
                Content = "Executor does not support HTTP",
                Duration = 3
            })
            return
